# Copia este arquivo pra scripts/.env e preenche os valores.
# scripts/.env está no .gitignore — NÃO commitar.

# ID da Instagram Business Account (obtido via Graph API Explorer):
#   GET /me/accounts → copia "id" da Page
#   GET /{page_id}?fields=instagram_business_account → copia "id" do retorno
IG_USER_ID=

# Long-lived Page Access Token (60 dias):
#   1. No Graph API Explorer gera user token com scopes:
#      instagram_basic, instagram_content_publish, pages_show_list,
#      pages_read_engagement, business_management
#   2. Troca por long-lived em:
#      https://graph.facebook.com/v21.0/oauth/access_token?grant_type=fb_exchange_token&client_id=APP_ID&client_secret=APP_SECRET&fb_exchange_token=SHORT_TOKEN
#   3. Pega o "access_token" do JSON de resposta
IG_ACCESS_TOKEN=

# URL pública das imagens. A pasta instagram-posts/ precisa estar acessível
# por HTTPS pra Graph API conseguir baixar. Opções:
#
# (a) Vercel — copia/move instagram-posts/ pra public/ e o Vite serve:
#     https://renegociaconsultoria.vercel.app/instagram-posts
#
# (b) Cloudinary/S3/R2 — sobe as PNGs e usa a URL base do bucket
#
# (c) Repo público no GitHub — a partir daí raw.githubusercontent.com funciona:
#     https://raw.githubusercontent.com/GabrielMendesIA/renegociaconsultoria/main/instagram-posts
IG_IMAGE_BASE_URL=
